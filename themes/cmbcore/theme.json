        {
          "key": "primary_color",
          "label": "Màu chính",
          "type": "color",
          "default": "#ed2524",
          "span": 8
        },
        {
          "key": "secondary_color",
          "label": "Màu phụ",
          "type": "color",
          "default": "#fb4908",
          "span": 8
        },
        {
          "key": "surface_dark",
          "label": "Nền tối",
          "type": "color",
          "default": "#000000",
          "span": 8
        }
