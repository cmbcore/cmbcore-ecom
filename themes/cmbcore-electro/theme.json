{
  "name": "CMBCORE Electro",
  "alias": "cmbcore-electro",
  "version": "1.0.0",
  "description": "Theme storefront phong cách điện tử dựa trên Electro HTML template — nền sáng, header tối, đỏ chủ đạo, product slick và newsletter.",
  "author": "Dev Team",
  "parent": "default",
  "supports": ["products", "blog", "pages"],
  "settings": [
    {
      "group": "colors",
      "label": "Bảng màu",
      "description": "Màu chủ đạo và nền được áp dụng đồng bộ cho toàn bộ storefront.",
      "fields": [
        {
          "key": "primary_color",
          "label": "Màu chính",
          "type": "color",
          "default": "#D10024",
          "span": 8
        },
        {
          "key": "dark_bg",
          "label": "Nền tối header",
          "type": "color",
          "default": "#15161D",
          "span": 8
        },
        {
          "key": "top_header_bg",
          "label": "Nền top header",
          "type": "color",
          "default": "#1E1F29",
          "span": 8
        }
      ]
    },
    {
      "group": "branding",
      "label": "Thương hiệu",
      "description": "Logo, liên hệ và các thành phần nhận diện dùng chung trên header và footer.",
      "fields": [
        {
          "key": "logo_image",
          "label": "Logo",
          "type": "image",
          "default": "/theme-assets/cmbcore-electro/images/logo.png",
          "span": 8
        },
        {
          "key": "logo_alt",
          "label": "Alt logo",
          "type": "text",
          "default": "CMBCORE Electro",
          "span": 8
        },
        {
          "key": "footer_contact",
          "label": "Thông tin footer",
          "type": "object",
          "fields": [
            {
              "key": "company",
              "label": "Tên công ty",
              "type": "text",
              "default": "CMBCORE Store",
              "span": 12
            },
            {
              "key": "address",
              "label": "Địa chỉ",
              "type": "textarea",
              "rows": 3,
              "default": "",
              "span": 24
            },
            {
              "key": "phone",
              "label": "Số điện thoại",
              "type": "text",
              "default": "",
              "span": 8
            },
            {
              "key": "email",
              "label": "Email",
              "type": "text",
              "default": "",
              "span": 8
            }
          ],
          "default": {
            "company": "CMBCORE Store",
            "address": "",
            "phone": "",
            "email": ""
          }
        },
        {
          "key": "facebook_url",
          "label": "Facebook URL",
          "type": "text",
          "default": "#",
          "span": 8
        },
        {
          "key": "twitter_url",
          "label": "Twitter URL",
          "type": "text",
          "default": "#",
          "span": 8
        },
        {
          "key": "instagram_url",
          "label": "Instagram URL",
          "type": "text",
          "default": "#",
          "span": 8
        }
      ]
    },
    {
      "group": "layout",
      "label": "Bố cục",
      "description": "Số lượng sản phẩm và bài viết trên mỗi trang.",
      "fields": [
        {
          "key": "products_per_page",
          "label": "Sản phẩm mỗi trang",
          "type": "number",
          "default": 12,
          "min": 4,
          "max": 48,
          "span": 6
        },
        {
          "key": "blog_posts_per_page",
          "label": "Bài viết mỗi trang",
          "type": "number",
          "default": 6,
          "min": 3,
          "max": 24,
          "span": 6
        },
        {
          "key": "home_products_per_section",
          "label": "Sản phẩm mỗi block trang chủ",
          "type": "number",
          "default": 8,
          "min": 4,
          "max": 12,
          "span": 6
        }
      ]
    },
    {
      "group": "copy",
      "label": "Nội dung dùng chung",
      "description": "Các nhãn và CTA dùng chung cho header, footer và trang chủ.",
      "fields": [
        {
          "key": "home_new_products_title",
          "label": "Tiêu đề sản phẩm mới trang chủ",
          "type": "text",
          "default": "",
          "span": 8
        },
        {
          "key": "home_top_selling_title",
          "label": "Tiêu đề bán chạy trang chủ",
          "type": "text",
          "default": "",
          "span": 8
        },
        {
          "key": "home_hot_deal_title",
          "label": "Tiêu đề deal hot trang chủ",
          "type": "text",
          "default": "",
          "span": 8
        },
        {
          "key": "newsletter_enabled",
          "label": "Hiển thị newsletter",
          "type": "select",
          "default": "1",
          "options": [
            { "label": "Có", "value": "1" },
            { "label": "Không", "value": "0" }
          ],
          "span": 6
        },
        {
          "key": "mobile_toolbar_items",
          "label": "Mobile toolbar",
          "type": "repeater",
          "fields": [
            { "key": "label", "label": "Nhãn", "type": "text", "default": "", "span": 6 },
            { "key": "url", "label": "Liên kết", "type": "text", "default": "", "span": 8 },
            { "key": "icon", "label": "Font icon", "type": "text", "default": "fa fa-home", "span": 6 },
            {
              "key": "target",
              "label": "Kiểu mở",
              "type": "select",
              "default": "_self",
              "span": 4,
              "options": [
                { "label": "Cùng tab", "value": "_self" },
                { "label": "Tab mới", "value": "_blank" }
              ]
            }
          ],
          "default": [
            { "label": "Trang chủ", "url": "/", "icon": "fa fa-home", "target": "_self" },
            { "label": "Sản phẩm", "url": "/san-pham", "icon": "fa fa-shopping-bag", "target": "_self" },
            { "label": "Giỏ hàng", "url": "/gio-hang", "icon": "fa fa-shopping-cart", "target": "_self" },
            { "label": "Tài khoản", "url": "/tai-khoan/dang-nhap", "icon": "fa fa-user", "target": "_self" }
          ]
        }
      ]
    },
    {
      "group": "home",
      "label": "Trang chủ",
      "description": "Quản lý category banners và hero area trên trang chủ.",
      "fields": [
        {
          "key": "home_category_banners",
          "label": "Category banners",
          "type": "repeater",
          "fields": [
            {
              "key": "image",
              "label": "Ảnh banner",
              "type": "image",
              "default": null,
              "span": 12
            },
            {
              "key": "title",
              "label": "Tiêu đề",
              "type": "text",
              "default": "",
              "span": 8
            },
            {
              "key": "url",
              "label": "Liên kết",
              "type": "text",
              "default": "#",
              "span": 8
            }
          ],
          "default": []
        }
      ]
    }
  ],
  "templates": {
    "page": [
      { "name": "default", "label": "Mặc định" }
    ]
  },
  "menus": [
    {
      "alias": "main_menu",
      "label": "Menu chính",
      "description": "Menu điều hướng chính của header storefront.",
      "items": [
        { "label": "Trang chủ", "url": "/", "icon": null, "target": "_self" },
        { "label": "Sản phẩm", "url": "/san-pham", "icon": null, "target": "_self" },
        { "label": "Tin tức", "url": "/bai-viet", "icon": null, "target": "_self" },
        { "label": "Giới thiệu", "url": "/gioi-thieu/", "icon": null, "target": "_self" }
      ]
    },
    {
      "alias": "footer_categories_menu",
      "label": "Footer danh mục",
      "description": "Nhóm link danh mục sản phẩm ở footer.",
      "items": [
        { "label": "Tất cả sản phẩm", "url": "/san-pham", "icon": null, "target": "_self" }
      ]
    },
    {
      "alias": "footer_info_menu",
      "label": "Footer thông tin",
      "description": "Nhóm link thông tin ở footer.",
      "items": [
        { "label": "Giới thiệu", "url": "/gioi-thieu/", "icon": null, "target": "_self" },
        { "label": "Liên hệ", "url": "/gioi-thieu/", "icon": null, "target": "_self" },
        { "label": "Chính sách bảo mật", "url": "/chinh-sach-bao-mat/", "icon": null, "target": "_self" }
      ]
    },
    {
      "alias": "footer_service_menu",
      "label": "Footer dịch vụ",
      "description": "Nhóm link dịch vụ ở footer.",
      "items": [
        { "label": "Tài khoản", "url": "/tai-khoan/dang-nhap", "icon": null, "target": "_self" },
        { "label": "Giỏ hàng", "url": "/gio-hang", "icon": null, "target": "_self" },
        { "label": "Yêu thích", "url": "/yeu-thich", "icon": null, "target": "_self" }
      ]
    }
  ]
}
